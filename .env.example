# Static deploy config
# Use / for Cloudflare Pages or a custom domain.
# Use <repo-name> for GitHub Pages project sites, for example:
# VITE_BASE_PATH=wallcloud-weather-dashboard
VITE_BASE_PATH=/

# Optional AI summary provider config.
# VITE_LLM_API_ENDPOINT must point to a non-secret proxy endpoint.
# Do not put secret API keys in public GitHub Pages or Cloudflare Pages builds:
# every VITE_* value is bundled into client-side JavaScript.

VITE_LLM_MODEL=openai/gpt-4o-mini
VITE_LLM_API_ENDPOINT=

# Optional basemap tile templates. Use public/proxy-safe tile URLs only; VITE_* values are public.
# Examples should include {z}/{x}/{y} placeholders. Leave blank to keep the black ops basemap only.
VITE_BING_ROAD_TILE_TEMPLATE=
VITE_BING_AERIAL_TILE_TEMPLATE=
VITE_GOOGLE_ROAD_TILE_TEMPLATE=
VITE_GOOGLE_SATELLITE_TILE_TEMPLATE=

# Optional Rust Level2 radar backend contract. Leave blank to use RainViewer fallback.
# Metadata endpoint may return { generated, healthMessage, frames: [{ time, tileUrlTemplate }] }.
# Tile template supports {station}, {product}, {z}, {x}, {y} placeholders.
VITE_LEVEL2_RADAR_METADATA_URL=
VITE_LEVEL2_RADAR_TILE_TEMPLATE=
VITE_LEVEL2_RADAR_STATION=KTLX
VITE_LEVEL2_RADAR_PRODUCT=ref
